# goholesail HOST configuration — copy to .env.host and edit:
#   cp .env.host.example .env.host

# Local TCP port on THIS machine to expose through the tunnel (e.g. 22 = ssh).
LIVE=22

# Hub /p2p multiaddr to dial out to (from the hub's startup logs; replace the
# 0.0.0.0 in that address with the hub's public IP).
HUB=/ip4/203.0.113.10/tcp/4001/p2p/12D3KooW...

# Stable identity seed. Empty = ephemeral peer id (the ghs:// string changes on
# every restart). Set a non-empty secret string for a stable identity.
SEED=

# Private mode: set PRIVATE=1 and a SECRET to require a shared secret from
# clients (the secret is verified locally, never sent to the hub registry).
PRIVATE=
SECRET=

# Optional: publish in the hub registry under a name + tags.
NAME=
TAGS=
