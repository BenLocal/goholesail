# goholesail hub configuration — copy to .env and edit:
#   cp .env.example .env

# TCP port the hub listens on inside the container AND publishes on the host.
# These are intentionally the same value: the hub advertises its listen port in
# its /p2p dial address, so the public port must match, or clients dial a port
# that isn't mapped.
HUB_PORT=4001

# Host interface to publish on:
#   0.0.0.0    -> all interfaces (reachable from the public IP)
#   127.0.0.1  -> localhost only
#   <ip>       -> one specific interface
HUB_PUBLISH_ADDR=0.0.0.0

# Stable identity seed. LEAVE EMPTY for an ephemeral peer id that changes on
# every restart (which invalidates every --hub / ghs:// string that embeds it).
# Set a non-empty secret string to keep the hub's peer id stable across
# restarts and redeploys — do this for any real deployment.
HUB_SEED=

# Public multiaddr the hub should announce. Set this when the hub runs behind
# NAT or inside Docker and cannot auto-detect its public IP. Format:
#   /ip4/<PUBLIC_IP>/tcp/<HUB_PORT>
# Leave empty if the hub can directly see its public interface.
HUB_ANNOUNCE_ADDR=
